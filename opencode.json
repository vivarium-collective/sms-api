{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/deepseek-coder-v2",
  "provider": {
    "ollama": {
      "api": "http://localhost:11434/v1"
    }
  },
  "agent": {
    "atlantis-dev": {
      "name": "atlantis-dev",
      "description": "Primary SMS-API / Atlantis full-stack dev agent. Knows the full architecture, deploy loop, EUTE workflow, and all three client surfaces (CLI/TUI/GUI).",
      "model": "ollama/deepseek-coder-v2",
      "mode": "primary",
      "tools": {
        "bash": true,
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "webfetch": false,
        "task": true,
        "todowrite": true,
        "list": true,
        "codesearch": true
      },
      "permission": {
        "bash": "allow",
        "read": "allow",
        "edit": "allow",
        "write": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "allow",
        "todowrite": "allow",
        "doom_loop": "ask"
      }
    },
    "architect": {
      "name": "architect",
      "description": "Read-heavy design and code-review agent. Explores the codebase, identifies patterns, flags over-engineering. No bash execution. Ideal for planning and PR review.",
      "model": "ollama/deepseek-coder-v2",
      "mode": "primary",
      "tools": {
        "bash": false,
        "read": true,
        "write": false,
        "edit": false,
        "glob": true,
        "grep": true,
        "webfetch": false,
        "task": false,
        "todowrite": false,
        "list": true,
        "codesearch": true
      },
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "deny",
        "write": "deny",
        "edit": "deny",
        "doom_loop": "deny"
      }
    },
    "tester": {
      "name": "tester",
      "description": "Test writer and runner. Knows pytest-asyncio, testcontainers, the fixture structure in tests/fixtures/, and the mock patterns for SSH/SLURM/EBI. Runs uv run pytest -x on changes.",
      "model": "ollama/deepseek-coder-v2",
      "mode": "primary",
      "tools": {
        "bash": true,
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "webfetch": false,
        "task": true,
        "todowrite": false,
        "list": true,
        "codesearch": true
      },
      "permission": {
        "bash": "allow",
        "read": "allow",
        "edit": "allow",
        "write": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "allow",
        "doom_loop": "ask"
      }
    },
    "security-auditor": {
      "name": "security-auditor",
      "description": "Read-only security review agent. Checks for OWASP top-10 issues, exposed secrets, SQL injection, command injection, unvalidated inputs, unsafe SSH patterns. No writes ever.",
      "model": "ollama/deepseek-coder-v2",
      "mode": "subagent",
      "tools": {
        "bash": false,
        "read": true,
        "write": false,
        "edit": false,
        "glob": true,
        "grep": true,
        "webfetch": false,
        "task": false,
        "todowrite": false,
        "list": true,
        "codesearch": true
      },
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "deny",
        "write": "deny",
        "edit": "deny",
        "doom_loop": "deny"
      }
    }
  }
}
