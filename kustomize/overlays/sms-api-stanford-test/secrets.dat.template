# Template for secrets_sms_eks.dat
# Copy this file to secrets_sms_eks.dat and fill in your actual values
# DO NOT commit secrets_sms_eks.dat to git

# Stack prefix from sms-cdk deployment (e.g., smscdk, smsvpctest)
# Used to look up resources from CloudFormation stack outputs
STACK_PREFIX="your-stack-prefix"

# GitHub credentials for container registry access
GH_USER_NAME=your_github_username
GH_USER_EMAIL=your_email@example.com
GH_PAT=ghp_YOURPERSONALACCESSTOKEN

# GitHub PAT for private repo clone during DooD builds
# This is the same PAT used for GHCR (GH_PAT above) — it needs repo read access
# Set to "use_gh_pat" to reuse GH_PAT, or provide a separate token
GITHUB_BUILD_PAT=use_gh_pat
