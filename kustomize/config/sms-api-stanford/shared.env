# Compute backend: "slurm" or "batch"
COMPUTE_BACKEND=batch
PUBLIC_MODE=false

# Messaging configuration (Redis)
REDIS_INTERNAL_HOST=smr1p1ccqiaewxyd.xfvggv.ng.0001.usgw1.cache.amazonaws.com
REDIS_INTERNAL_PORT=6379
REDIS_EXTERNAL_HOST=smr1p1ccqiaewxyd.xfvggv.ng.0001.usgw1.cache.amazonaws.com
REDIS_EXTERNAL_PORT=6379
REDIS_CHANNEL=worker.events
REDIS_EMITTER_MAGIC_WORD=redis-emitter-magic-word

# Docker image builds (DooD via AWS Batch)
# Queue names are looked up from CloudFormation by secrets.sh
BUILD_ARM64_QUEUE=smscdk-vecoli-build-arm64
BUILD_AMD64_QUEUE=smscdk-vecoli-build-amd64
BUILD_JOB_DEFINITION=smscdk-vecoli-dind-build
BUILD_GIT_SECRET_ARN=arn:aws-us-gov:secretsmanager:us-gov-west-1:476270107793:secret:vecoli-github-pat

K8S_JOB_NAMESPACE=sms-api-stanford
ECR_ACCOUNT_ID=476270107793
S3_WORK_BUCKET=
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-gov-west-1
BATCH_AMD64_QUEUE=smscdk-vecoli-task-amd64
BATCH_ARM64_QUEUE=smscdk-vecoli-task-arm64
BATCH_TASK_ARCH=arm64
MARIMO_API_SERVER=http://api:8000
DEPLOYMENT_NAMESPACE=sms-api-stanford
