# Default compute backend: "slurm" | "batch" | "ray". Used as the FALLBACK only —
# the backend is otherwise chosen per simulator from its repo (vEcoli→batch, v2ecoli→ray),
# so this one deployment serves both. RAY_* must be configured (below) for the ray path.
COMPUTE_BACKEND=batch
PUBLIC_MODE=false

# Messaging configuration (Redis)
REDIS_INTERNAL_HOST=smr1vbw3hwdxv21w.xfvggv.ng.0001.usgw1.cache.amazonaws.com
REDIS_INTERNAL_PORT=6379
REDIS_EXTERNAL_HOST=smr1vbw3hwdxv21w.xfvggv.ng.0001.usgw1.cache.amazonaws.com
REDIS_EXTERNAL_PORT=6379
REDIS_CHANNEL=worker.events
REDIS_EMITTER_MAGIC_WORD=redis-emitter-magic-word

# Docker image builds (DooD via AWS Batch)
BUILD_ARM64_QUEUE=smsvpctest-vecoli-build-arm64
BUILD_AMD64_QUEUE=smsvpctest-vecoli-build-amd64
BUILD_JOB_DEFINITION=smsvpctest-vecoli-dind-build
BUILD_GIT_SECRET_ARN=arn:aws-us-gov:secretsmanager:us-gov-west-1:476270107793:secret:vecoli-github-pat

K8S_JOB_NAMESPACE=sms-api-stanford-test
ECR_ACCOUNT_ID=476270107793
S3_WORK_BUCKET=smsvpctest-shared-sharedbucket60d199d6-abfvwv0day91
STORAGE_S3_BUCKET=smsvpctest-shared-sharedbucket60d199d6-abfvwv0day91
STORAGE_S3_REGION=us-gov-west-1
BATCH_AMD64_QUEUE=smsvpctest-vecoli-task-amd64
BATCH_ARM64_QUEUE=smsvpctest-vecoli-task-arm64
BATCH_TASK_ARCH=arm64

# Ray-on-Batch backend (used when COMPUTE_BACKEND=ray). The queue/job-def/log-prefix are
# re-resolved from CloudFormation by secrets.sh (smsvpctest-ray-batch / smsvpctest-ray).
RAY_MNP_QUEUE=smsvpctest-ray-mnp
RAY_MNP_JOB_DEFINITION=smsvpctest-ray-mnp
RAY_LOG_S3_PREFIX=s3://smsvpctest-shared-sharedbucket60d199d6-abfvwv0day91/ray-logs/
RAY_ECR_REPOSITORY=v2ecoli
RAY_NUM_NODES=3
RAY_PARCA_MODE=fast
RAY_PARCA_CPUS=8
RAY_N_STEPS=600
RAY_CHUNK=60

# Compose-on-Batch (generic process-bigraph runner). All three key off ONE identity:
# the workspace COMMIT. Keep them consistent — the image, the staged ParCa cache and
# the workbench's baked workspace must all describe the same v2ecoli.
#   a08e20bd… = v2ecoli origin/main HEAD, the ECR tag, and the ParCa cache key.
# The image tag has NO default (the ECR repo is per-commit and has no "latest"), so
# leaving this blank makes compose submits fail fast with the setting name.
COMPOSE_RAY_IMAGE_TAG=a08e20bd84da94743952d209bc39db4cc8837ea9
# Where the commit-keyed ParCa cache is staged before the run. v2ecoli's baseline
# resolves a relative "out/cache" against the image WORKDIR (/app/v2ecoli). Blank
# disables staging, which is right for composites that need no prebuilt cache.
COMPOSE_PARCA_CACHE_DIR=/app/v2ecoli/out/cache
# The workspace's own core builder. run_pbg.py's generic core registers only
# process-bigraph's base types + the pbg-emitters links; v2ecoli's build_core also
# registers ECOLI_TYPES, without which its documents don't resolve.
COMPOSE_PBG_CORE_BUILDER=v2ecoli.core:build_core

MARIMO_API_SERVER=http://api:8000
DEPLOYMENT_NAMESPACE=sms-api-stanford-test
